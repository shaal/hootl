{
  "taskBackend": "local",
  "budgets": {
    "perSession": 1.5,
    "perTask": 5,
    "global": 150,
    "maxAttemptsPerTask": 10
  },
  "confidence": {
    "target": 95,
    "requireTests": true
  },
  "git": {
    "useWorktrees": false,
    "autoPR": true,
    "branchPrefix": "hootl/"
  },
  "auto": {
    "defaultLevel": "proactive",
    "maxParallel": 1
  },
  "notifications": {
    "terminal": true,
    "osNotify": false,
    "summaryFile": true,
    "webhook": null
  },
  "permissionMode": "default"
}
